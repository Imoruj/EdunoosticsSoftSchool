enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String // e.g., "BULK_PDF_GENERATION"
  status      JobStatus @default(PENDING)
  progress    Int       @default(0) // 0-100
  totalItems  Int       @default(0)
  failedItems Int       @default(0)
  resultUrl   String? // S3 URL or path to ZIP
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy   String? // User ID who initiated the job
}

// ============ LOCAL-FIRST / E2E ENCRYPTED LMS MODELS ============

// Stores user's public keys for encryption
model DeviceKey {
  id                String   @id @default(cuid())
  userId            String
  deviceId          String   @unique
  deviceName        String?
  identityPublicKey String // ECDH public key (base64)
  signingPublicKey  String // ECDSA public key (base64)
  preKeys           Json? // Signal-style prekeys
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

// Sync coordination metadata (not actual content)
model SyncMetadata {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  entityType  String // 'lesson', 'quiz', 'assignment', 'message'
  entityId    String
  lastSyncAt  DateTime @default(now())
  vectorClock Json // CRDT vector clock
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId, entityType, entityId])
  @@index([userId, entityType])
}

// Encrypted data blobs (server cannot decrypt)
model EncryptedBlob {
  id            String    @id @default(cuid())
  userId        String
  blobType      String // 'lesson', 'quiz', 'assignment', 'message'
  entityId      String // Reference to the actual entity
  encryptedData Bytes // Encrypted content
  iv            String // Initialization vector
  signature     String? // Signature for verification
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime? // For temporary storage
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, blobType, entityId])
  @@index([userId, blobType])
  @@index([expiresAt])
}

model UploadedFile {
  id           String   @id @default(cuid())
  schoolId     String?
  uploadedById String
  uploadType   String
  originalName String
  storedName   String
  mimeType     String
  extension    String
  size         Int
  data         Bytes
  createdAt    DateTime @default(now())

  school     School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("UploadedFileOwner", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([schoolId, uploadType])
  @@index([uploadedById, createdAt])
}

enum StudentChangeRequestAction {
