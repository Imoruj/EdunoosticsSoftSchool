// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  CLASS_TEACHER
  SUBJECT_TEACHER
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
}

enum ClassLevel {
  NURSERY
  PRIMARY
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
}

enum SubjectCategory {
  CORE
  SCIENCE
  ARTS
  COMMERCIAL
  VOCATIONAL
  LANGUAGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  ONLINE
}

enum MessageChannel {
  SMS
  EMAIL
  IN_APP
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

// ============ MODELS ============

model School {
  id        String   @id @default(cuid())
  name      String
  motto     String?
  address   String?
  city      String?
  state     String?
  country   String   @default("Nigeria")
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  stampUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users            User[]
  academicSessions AcademicSession[]
  classes          Class[]
  subjects         Subject[]
  students         Student[]
  feeStructures    FeeStructure[]
  gradingRules     GradingRule[]
  assessmentTypes  AssessmentType[]
  psychomotorSkills PsychomotorSkill[]
  affectiveTraits   AffectiveTrait[]
  messages         Message[]
}


model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  roles        UserRole[]
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  school         School?       @relation(fields: [schoolId], references: [id])
  schoolId       String?
  classArms      ClassArm[]    @relation("ClassTeacher")
  teacherSubjects TeacherSubject[]
  scoresCreated  Score[]       @relation("ScoreCreator")
  scoresUpdated  Score[]       @relation("ScoreUpdater")
  attendanceMarked Attendance[] @relation("AttendanceMarker")
  paymentsReceived FeePayment[] @relation("PaymentReceiver")
  messagesSent   Message[]     @relation("MessageSender")
  parent         Parent?
  studentAccount Student?      @relation("StudentUser")
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   // e.g., "2025/2026"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String
  terms    Term[]

  @@unique([schoolId, name])
}

model Term {
  id              String   @id @default(cuid())
  name            String   // "First Term", "Second Term", "Third Term"
  termNumber      Int      // 1, 2, or 3
  startDate       DateTime
  endDate         DateTime
  resumptionDate  DateTime?
  isCurrent       Boolean  @default(false)
  totalSchoolDays Int?
  createdAt       DateTime @default(now())

  // Relations
  session      AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId    String
  scores       Score[]
  reportCards  ReportCard[]
  feeStructures FeeStructure[]
  feePayments  FeePayment[]

  @@unique([sessionId, termNumber])
}

model Class {
  id         String     @id @default(cuid())
  name       String     // "Primary 1", "JSS 2", "SSS 3"
  level      ClassLevel
  orderIndex Int        @default(0) // For sorting
  createdAt  DateTime   @default(now())

  // Relations
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId      String
  arms          ClassArm[]
  classSubjects ClassSubject[]
  feeStructures FeeStructure[]

  @@unique([schoolId, name])
}

model ClassArm {
  id       String @id @default(cuid())
  armName  String // "A", "B", "Science", "Arts"
  capacity Int    @default(50)
  createdAt DateTime @default(now())

  // Relations
  class          Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId        String
  classTeacher   User?     @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classTeacherId String?
  students       Student[]
  teacherSubjects TeacherSubject[]
  attendance     Attendance[]
  reportCards    ReportCard[]

  @@unique([classId, armName])
}

model Subject {
  id        String          @id @default(cuid())
  name      String
  code      String?
  category  SubjectCategory @default(CORE)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  // Relations
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId       String
  classSubjects  ClassSubject[]
  teacherSubjects TeacherSubject[]
  scores         Score[]

  @@unique([schoolId, name])
}

model ClassSubject {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Relations
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String

  @@unique([classId, subjectId])
}

model TeacherSubject {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Relations
  teacher    User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId  String
  classArm   ClassArm @relation(fields: [classArmId], references: [id], onDelete: Cascade)
  classArmId String

  @@unique([teacherId, subjectId, classArmId])
}

model Parent {
  id          String  @id @default(cuid())
  occupation  String?
  relationship String @default("guardian")
  createdAt   DateTime @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String    @unique
  students Student[]
}

model Student {
  id              String   @id @default(cuid())
  admissionNumber String
  firstName       String
  lastName        String
  otherNames      String?
  gender          Gender
  dateOfBirth     DateTime?
  parentName      String?
  parentPhone     String?
  parentEmail     String?
  address         String?
  stateOfOrigin   String?
  religion        String?
  bloodGroup      String?
  photoUrl        String?
  admissionDate   DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId    String
  classArm    ClassArm? @relation(fields: [classArmId], references: [id])
  classArmId  String?
  parent      Parent?   @relation(fields: [parentId], references: [id])
  parentId    String?
  user        User?     @relation("StudentUser", fields: [userId], references: [id])
  userId      String?   @unique
  scores      Score[]
  attendance  Attendance[]
  reportCards ReportCard[]
  feePayments FeePayment[]

  @@unique([schoolId, admissionNumber])
}

model Score {
  id              String   @id @default(cuid())
  ca1             Decimal  @default(0) @db.Decimal(5, 2)
  ca2             Decimal  @default(0) @db.Decimal(5, 2)
  ca3             Decimal  @default(0) @db.Decimal(5, 2)
  exam            Decimal  @default(0) @db.Decimal(5, 2)
  total           Decimal  @default(0) @db.Decimal(5, 2)
  grade           String?
  remark          String?
  subjectPosition Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  subject     Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String
  term        Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId      String
  createdBy   User?   @relation("ScoreCreator", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("ScoreUpdater", fields: [updatedById], references: [id])
  updatedById String?

  @@unique([studentId, subjectId, termId])
}

model ReportCard {
  id               String   @id @default(cuid())
  totalScore       Decimal? @db.Decimal(10, 2)
  totalObtainable  Int?
  average          Decimal? @db.Decimal(5, 2)
  classPosition    Int?
  classSize        Int?
  daysPresent      Int?
  daysAbsent       Int?
  totalSchoolDays  Int?
  classTeacherComment String?
  principalComment String?
  accessPin        String?
  isPublished      Boolean  @default(false)
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  student           Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId         String
  term              Term               @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId            String
  classArm          ClassArm           @relation(fields: [classArmId], references: [id])
  classArmId        String
  psychomotorRatings PsychomotorRating[]
  affectiveRatings   AffectiveRating[]

  @@unique([studentId, termId])
}

model PsychomotorSkill {
  id         String   @id @default(cuid())
  name       String
  orderIndex Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relations
  school   School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String?
  ratings  PsychomotorRating[]

  @@unique([schoolId, name])
}

model PsychomotorRating {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  createdAt DateTime @default(now())

  // Relations
  reportCard   ReportCard       @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  reportCardId String
  skill        PsychomotorSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId      String

  @@unique([reportCardId, skillId])
}

model AffectiveTrait {
  id         String   @id @default(cuid())
  name       String
  orderIndex Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relations
  school   School?           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String?
  ratings  AffectiveRating[]

  @@unique([schoolId, name])
}

model AffectiveRating {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  createdAt DateTime @default(now())

  // Relations
  reportCard   ReportCard     @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  reportCardId String
  trait        AffectiveTrait @relation(fields: [traitId], references: [id], onDelete: Cascade)
  traitId      String

  @@unique([reportCardId, traitId])
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime         @default(now())

  // Relations
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  classArm   ClassArm @relation(fields: [classArmId], references: [id])
  classArmId String
  markedBy   User?    @relation("AttendanceMarker", fields: [markedById], references: [id])
  markedById String?

  @@unique([studentId, date])
}

model GradingRule {
  id       String   @id @default(cuid())
  minScore Int
  maxScore Int
  grade    String
  remark   String
  createdAt DateTime @default(now())

  // Relations
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String?

  @@unique([schoolId, grade])
}

model AssessmentType {
  id        String   @id @default(cuid())
  name      String   // e.g., "CA1", "CA2", "Exam", "Project"
  shortName String?  // e.g., "CA1", "CA2", "EX"
  maxScore  Int      // Maximum score for this assessment type
  order     Int      @default(0) // Display order
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String

  @@unique([schoolId, name])
}

model FeeStructure {
  id      String   @id @default(cuid())
  feeType String
  amount  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  // Relations
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId  String
  term     Term   @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId   String

  @@unique([schoolId, classId, termId, feeType])
}

model FeePayment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  reference     String?
  paymentDate   DateTime
  createdAt     DateTime      @default(now())

  // Relations
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  term        Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId      String
  receivedBy  User?   @relation("PaymentReceiver", fields: [receivedById], references: [id])
  receivedById String?
}

model Message {
  id            String        @id @default(cuid())
  recipientType String        // "all", "class", "individual"
  recipientId   String?
  subject       String?
  body          String
  channel       MessageChannel
  status        MessageStatus @default(PENDING)
  sentAt        DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id])
  senderId String
}
