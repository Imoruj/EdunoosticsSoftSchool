generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                          String                   @id @default(cuid())
  name                        String
  motto                       String?
  address                     String?
  city                        String?
  state                       String?
  country                     String                   @default("Nigeria")
  phone                       String?
  email                       String?
  website                     String?
  logoUrl                     String?
  primaryColor                String                   @default("#16a34a") // Brand color (default primary-600)
  slug                        String?                  @unique // URL-friendly name for branded login
  principalSignatureUrl       String?
  stampUrl                    String?
  allowStudentAdmissionNumberLogin Boolean            @default(true)
  allowStudentEmailLogin      Boolean                  @default(true)
  isActive                    Boolean                  @default(true)
  registrationStatus          SchoolRegistrationStatus @default(APPROVED)
  registrationRejectionReason String?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  academicSessions            AcademicSession[]
  affectiveTraits             AffectiveTrait[]
  aiSettings                  AiSettings?
  assessmentTypes             AssessmentType[]
  classes                     Class[]
  feeStructures               FeeStructure[]
  gradingRules                GradingRule[]
  messages                    Message[]
  psychomotorSkills           PsychomotorSkill[]
  students                    Student[]
  subjects                    Subject[]
  compositeSubjectConfigs     CompositeSubjectConfig[]
  users                       User[]
  reportCardConfig            ReportCardConfig?
  communicationConfig         CommunicationConfig?
  broadsheetConfig            BroadsheetConfig?
  featureControls             SchoolFeatureControl?
  rolePermissionControls      RolePermissionControl[]
  backgroundJobs              BackgroundJob[]
  scoreSheetWorkflows         ScoreSheetWorkflow[]
  classReportWorkflows        ClassReportWorkflow[]
  studentReportWorkflows      StudentReportWorkflow[]
  notifications               UserNotification[]
  uploadedFiles               UploadedFile[]
  studentChangeRequests       StudentChangeRequest[]
  schemesOfWork               SchemeOfWork[]
  publicHolidays              PublicHoliday[]
  organizationId              String?
  branchCode                  String?
  isHeadBranch                Boolean                  @default(false)
  organization                Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userBranches                UserBranch[]
  studentTransfersFrom        StudentTransfer[]        @relation("TransferFrom")
  studentTransfersTo          StudentTransfer[]        @relation("TransferTo")

  @@index([organizationId])
}

model User {
  id                                    String                     @id @default(cuid())
  email                                 String                     @unique
  passwordHash                          String
  firstName                             String
  lastName                              String
  phone                                 String?
  roles                                 UserRole[]
  avatarUrl                             String?
  signatureUrl                          String? // For class teacher/principal signatures
  isActive                              Boolean                    @default(true)
  mustChangePassword                    Boolean                    @default(true)
  canSwitchBranches                     Boolean                    @default(true)
  lastLogin                             DateTime?
  createdAt                             DateTime                   @default(now())
  updatedAt                             DateTime                   @updatedAt
  schoolId                              String?
  attendanceMarked                      Attendance[]               @relation("AttendanceMarker")
  classArms                             ClassArm[]                 @relation("ClassTeacher")
  paymentsReceived                      FeePayment[]               @relation("PaymentReceiver")
  messagesSent                          Message[]                  @relation("MessageSender")
  parent                                Parent?
  scoresCreated                         Score[]                    @relation("ScoreCreator")
  scoresUpdated                         Score[]                    @relation("ScoreUpdater")
  studentAccount                        Student?                   @relation("StudentUser")
  teacherSubjects                       TeacherSubject[]
  scoreUploadRequests                   ScoreUploadRequest[]       @relation("ScoreUploader")
  scoreUploadReviews                    ScoreUploadRequest[]       @relation("ScoreReviewer")
  scoreSheetWorkflowsAsSubjectTeacher   ScoreSheetWorkflow[]       @relation("ScoreWorkflowSubjectTeacher")
  scoreSheetWorkflowsAsClassTeacher     ScoreSheetWorkflow[]       @relation("ScoreWorkflowClassTeacher")
  scoreSheetWorkflowsReviewed           ScoreSheetWorkflow[]       @relation("ScoreWorkflowReviewer")
  scoreSheetWorkflowsBroadcasted        ScoreSheetWorkflow[]       @relation("ScoreWorkflowBroadcaster")
  scoreSheetActionLogs                  ScoreSheetActionLog[]      @relation("ScoreWorkflowActionActor")
  classReportWorkflowsResultBroadcasted ClassReportWorkflow[]      @relation("ClassReportResultBroadcaster")
  classReportWorkflowsCommentsGenerated ClassReportWorkflow[]      @relation("ClassReportCommentsGenerator")
  classReportWorkflowsPublished         ClassReportWorkflow[]      @relation("ClassReportPublisher")
  classReportWorkflowsUnpublished       ClassReportWorkflow[]      @relation("ClassReportUnpublisher")
  studentReportWorkflowsClassApproved   StudentReportWorkflow[]    @relation("StudentReportClassApprover")
  studentReportWorkflowsAdminReviewed   StudentReportWorkflow[]    @relation("StudentReportAdminReviewer")
  notifications                         UserNotification[]         @relation("UserNotifications")
  school                                School?                    @relation(fields: [schoolId], references: [id])
  deviceKeys                            DeviceKey[]
  syncMetadata                          SyncMetadata[]
  encryptedBlobs                        EncryptedBlob[]
  uploadedFiles                         UploadedFile[]             @relation("UploadedFileOwner")
  signalingMessagesFrom                 SignalingMessage[]         @relation("SignalingFrom")
  signalingMessagesTo                   SignalingMessage[]         @relation("SignalingTo")
  schemesOfWorkOwned                    SchemeOfWork[]             @relation("SOWOwner")
  schemesOfWorkApproved                 SchemeOfWork[]             @relation("SOWApprover")
  schemeOfWorkTermsApproved             SchemeOfWorkTerm[]         @relation("SOWTermApprover")
  schemeOfWorkCollaborators             SchemeOfWorkCollaborator[]
  studentChangeRequestsRequested        StudentChangeRequest[]     @relation("StudentChangeRequester")
  studentChangeRequestsReviewed         StudentChangeRequest[]     @relation("StudentChangeReviewer")
  branches                              UserBranch[]               @relation("UserBranches")
  branchAssignments                     UserBranch[]               @relation("BranchAssignedBy")
  studentTransfers                      StudentTransfer[]          @relation("TransferActor")
}

model AcademicSession {
  id                      String                   @id @default(cuid())
  name                    String
  startDate               DateTime
  endDate                 DateTime
  isCurrent               Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  schoolId                String
  school                  School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms                   Term[]
  schemesOfWork           SchemeOfWork[]
  compositeSubjectConfigs CompositeSubjectConfig[]

  @@unique([schoolId, name])
}

model Term {
  id                     String                  @id @default(cuid())
  name                   String
  termNumber             Int
  startDate              DateTime
  endDate                DateTime
  resumptionDate         DateTime?
  isCurrent              Boolean                 @default(false)
  totalWeeks             Int?
  totalSchoolDays        Int?
  createdAt              DateTime                @default(now())
  sessionId              String
  feePayments            FeePayment[]
  feeStructures          FeeStructure[]
  reportCards            ReportCard[]
  scores                 Score[]
  subjectEnrollments     SubjectEnrollment[]
  scoreUploadRequests    ScoreUploadRequest[]
  scoreSheetWorkflows    ScoreSheetWorkflow[]
  classReportWorkflows   ClassReportWorkflow[]
  studentReportWorkflows StudentReportWorkflow[]
  schemeOfWorkTerms      SchemeOfWorkTerm[]
  session                AcademicSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, termNumber])
}

model Class {
  id                      String                   @id @default(cuid())
  name                    String
  level                   ClassLevel
  orderIndex              Int                      @default(0)
  createdAt               DateTime                 @default(now())
  schoolId                String
  school                  School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  arms                    ClassArm[]
  feeStructures           FeeStructure[]
  schemesOfWork           SchemeOfWork[]
  classAssessmentTypes    ClassAssessmentType[]
  compositeSubjectConfigs CompositeSubjectConfig[]

  @@unique([schoolId, name])
}

model ClassArm {
  id                     String                  @id @default(cuid())
  armName                String
  capacity               Int                     @default(50)
  createdAt              DateTime                @default(now())
  classId                String
  classTeacherId         String?
  attendance             Attendance[]
  class                  Class                   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher           User?                   @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  reportCards            ReportCard[]
  students               Student[]
  subjectEnrollments     SubjectEnrollment[]
  teacherSubjects        TeacherSubject[]
  subjectClassArms       SubjectClassArm[]
  scoreUploadRequests    ScoreUploadRequest[]
  scoreSheetWorkflows    ScoreSheetWorkflow[]
  classReportWorkflows   ClassReportWorkflow[]
  studentReportWorkflows StudentReportWorkflow[]
  schemeOfWorkClassArms  SchemeOfWorkClassArm[]
  studentTransfersFrom   StudentTransfer[]       @relation("TransferFromArm")
  studentTransfersTo     StudentTransfer[]       @relation("TransferToArm")

  @@unique([classId, armName])
}

model Subject {
  id                        String                      @id @default(cuid())
  name                      String
  code                      String?
  category                  SubjectCategory             @default(CORE)
  subjectKind               SubjectKind                 @default(STANDARD)
  defaultParentSubjectId    String?
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  schoolId                  String
  subjectClassArms          SubjectClassArm[]
  subjectEnrollments        SubjectEnrollment[]
  scores                    Score[]
  scoreUploadRequests       ScoreUploadRequest[]
  scoreSheetWorkflows       ScoreSheetWorkflow[]
  school                    School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherSubjects           TeacherSubject[]
  schemesOfWork             SchemeOfWork[]
  defaultParentSubject      Subject?                    @relation("DefaultCompositeParent", fields: [defaultParentSubjectId], references: [id], onDelete: SetNull)
  defaultComponentSubjects  Subject[]                   @relation("DefaultCompositeParent")
  parentCompositeConfigs    CompositeSubjectConfig[]    @relation("CompositeParentSubject")
  componentCompositeEntries CompositeSubjectComponent[] @relation("CompositeComponentSubject")
  derivedEnrollmentChildren SubjectEnrollment[]         @relation("DerivedEnrollmentSource")

  @@unique([schoolId, name])
}

model CompositeSubjectConfig {
  id              String                      @id @default(cuid())
  schoolId        String
  sessionId       String
  classId         String
  parentSubjectId String
  isActive        Boolean                     @default(true)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  school          School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session         AcademicSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  class           Class                       @relation(fields: [classId], references: [id], onDelete: Cascade)
  parentSubject   Subject                     @relation("CompositeParentSubject", fields: [parentSubjectId], references: [id], onDelete: Cascade)
  components      CompositeSubjectComponent[]
  derivedScores   Score[]                     @relation("DerivedCompositeScores")

  @@unique([sessionId, classId, parentSubjectId])
  @@index([schoolId, sessionId, classId])
}

model CompositeSubjectComponent {
  id                 String                 @id @default(cuid())
  compositeConfigId  String
  componentSubjectId String
  orderIndex         Int                    @default(0)
  ca1Max             Decimal                @default(0) @db.Decimal(5, 2)
  ca2Max             Decimal                @default(0) @db.Decimal(5, 2)
  ca3Max             Decimal                @default(0) @db.Decimal(5, 2)
  examMax            Decimal                @default(0) @db.Decimal(5, 2)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  compositeConfig    CompositeSubjectConfig @relation(fields: [compositeConfigId], references: [id], onDelete: Cascade)
  componentSubject   Subject                @relation("CompositeComponentSubject", fields: [componentSubjectId], references: [id], onDelete: Cascade)

  @@unique([compositeConfigId, componentSubjectId])
  @@index([componentSubjectId])
}

model SubjectClassArm {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  subjectId  String
  classArmId String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classArm   ClassArm @relation(fields: [classArmId], references: [id], onDelete: Cascade)

  @@unique([subjectId, classArmId])
  @@index([subjectId])
  @@index([classArmId])
}

model TeacherSubject {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  teacherId  String
  subjectId  String
  classArmId String
  classArm   ClassArm @relation(fields: [classArmId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, classArmId])
  @@unique([subjectId, classArmId])
}

model Parent {
  id           String    @id @default(cuid())
  occupation   String?
  relationship String    @default("guardian")
  createdAt    DateTime  @default(now())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students     Student[]
}

model Student {
  id                     String                  @id @default(cuid())
  admissionNumber        String
  firstName              String
  lastName               String
  otherNames             String?
  gender                 Gender
  dateOfBirth            DateTime?
  parentName             String?
  parentPhone            String?
  parentEmail            String?
  address                String?
  stateOfOrigin          String?
  religion               String?
  bloodGroup             String?
  photoUrl               String?
  admissionDate          DateTime?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  schoolId               String
  classArmId             String?
  parentId               String?
  userId                 String?                 @unique
  attendance             Attendance[]
  feePayments            FeePayment[]
  reportCards            ReportCard[]
  scores                 Score[]
  subjectEnrollments     SubjectEnrollment[]
  studentReportWorkflows StudentReportWorkflow[]
  classArm               ClassArm?               @relation(fields: [classArmId], references: [id])
  parent                 Parent?                 @relation(fields: [parentId], references: [id])
  school                 School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                   User?                   @relation("StudentUser", fields: [userId], references: [id])
  changeRequests         StudentChangeRequest[]
  transfers              StudentTransfer[]

  @@unique([schoolId, admissionNumber])
}

model SubjectEnrollment {
  id                   String   @id @default(cuid())
  studentId            String
  subjectId            String
  classArmId           String
  termId               String
  isActive             Boolean  @default(true)
  isDerived            Boolean  @default(false)
  derivedFromSubjectId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classArm           ClassArm @relation(fields: [classArmId], references: [id], onDelete: Cascade)
  term               Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  derivedFromSubject Subject? @relation("DerivedEnrollmentSource", fields: [derivedFromSubjectId], references: [id], onDelete: SetNull)

  @@unique([studentId, subjectId, termId])
  @@index([subjectId, classArmId, termId])
  @@index([studentId, termId])
}

model Score {
  id                           String                  @id @default(cuid())
  scoreValues                  Json                    @default("{}")
  componentScores              Json                    @default("{}")
  total                        Decimal                 @default(0) @db.Decimal(5, 2)
  grade                        String?
  remark                       String?
  subjectPosition              Int?
  isDerived                    Boolean                 @default(false)
  derivedFromCompositeConfigId String?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  studentId                    String
  subjectId                    String
  termId                       String
  createdById                  String?
  updatedById                  String?
  createdBy                    User?                   @relation("ScoreCreator", fields: [createdById], references: [id])
  student                      Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject                      Subject                 @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term                         Term                    @relation(fields: [termId], references: [id], onDelete: Cascade)
  updatedBy                    User?                   @relation("ScoreUpdater", fields: [updatedById], references: [id])
  derivedFromCompositeConfig   CompositeSubjectConfig? @relation("DerivedCompositeScores", fields: [derivedFromCompositeConfigId], references: [id], onDelete: SetNull)

  @@unique([studentId, subjectId, termId])
  @@index([termId, subjectId])
  @@index([studentId, termId])
}

model ReportCard {
  id                  String              @id @default(cuid())
  totalScore          Decimal?            @db.Decimal(10, 2)
  totalObtainable     Int?
  average             Decimal?            @db.Decimal(5, 2)
  classPosition       Int?
  classSize           Int?
  daysPresent         Int?
  daysAbsent          Int?
  totalSchoolDays     Int?
  classTeacherComment String?
  principalComment    String?
  accessPin           String?
  isPublished         Boolean             @default(false)
  publishedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  studentId           String
  termId              String
  classArmId          String
  affectiveRatings    AffectiveRating[]
  psychomotorRatings  PsychomotorRating[]
  classArm            ClassArm            @relation(fields: [classArmId], references: [id])
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                Term                @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId])
  @@index([termId, classArmId])
  @@index([classArmId, isPublished])
}

model PsychomotorSkill {
  id         String              @id @default(cuid())
  name       String
  orderIndex Int
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  schoolId   String?
  ratings    PsychomotorRating[]
  school     School?             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
}

model PsychomotorRating {
  id           String           @id @default(cuid())
  rating       Int
  createdAt    DateTime         @default(now())
  reportCardId String
  skillId      String
  reportCard   ReportCard       @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  skill        PsychomotorSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([reportCardId, skillId])
}

model AffectiveTrait {
  id         String            @id @default(cuid())
  name       String
  orderIndex Int
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  schoolId   String?
  ratings    AffectiveRating[]
  school     School?           @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
}

model AffectiveRating {
  id           String         @id @default(cuid())
  rating       Int
  createdAt    DateTime       @default(now())
  reportCardId String
  traitId      String
  reportCard   ReportCard     @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  trait        AffectiveTrait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([reportCardId, traitId])
}

model Attendance {
  id         String             @id @default(cuid())
  date       DateTime
  period     AttendancePeriod   @default(MORNING)
  status     AttendanceStatus   @default(PRESENT)
  createdAt  DateTime           @default(now())
  studentId  String
  classArmId String
  markedById String?
  classArm   ClassArm           @relation(fields: [classArmId], references: [id])
  markedBy   User?              @relation("AttendanceMarker", fields: [markedById], references: [id])
  student    Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, period])
}

model PublicHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date])
}

model GradingRule {
  id             String          @id @default(cuid())
  minScore       Float
  maxScore       Float
  grade          String
  remark         String
  createdAt      DateTime        @default(now())
  schoolId       String?
  schoolCategory SchoolCategory?
  school         School?         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, grade, schoolCategory])
}

model AssessmentType {
  id             String   @id @default(cuid())
  name           String
  shortName      String?
  maxScore       Int
  includeInTotal Boolean  @default(true)
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  components     AssessmentTypeComponent[]

  @@unique([schoolId, name])
}

model AssessmentTypeComponent {
  id               String         @id @default(cuid())
  assessmentTypeId String
  assessmentType   AssessmentType @relation(fields: [assessmentTypeId], references: [id], onDelete: Cascade)
  name             String
  maxScore         Float
  order            Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([assessmentTypeId, name])
  @@index([assessmentTypeId])
}

model ClassAssessmentType {
  id             String   @id @default(cuid())
  name           String
  shortName      String?
  maxScore       Int
  includeInTotal Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, name])
}

model FeeStructure {
  id        String   @id @default(cuid())
  feeType   String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  schoolId  String
  classId   String
  termId    String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, termId, feeType])
}

model FeePayment {
  id            String         @id @default(cuid())
  amount        Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  reference     String?
  paymentDate   DateTime
  createdAt     DateTime       @default(now())
  studentId     String
  termId        String
  receivedById  String?
  receivedBy    User?          @relation("PaymentReceiver", fields: [receivedById], references: [id])
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term          Term           @relation(fields: [termId], references: [id], onDelete: Cascade)
}

model Message {
  id            String         @id @default(cuid())
  recipientType String
  recipientId   String?
  subject       String?
  body          String
  channel       MessageChannel
  status        MessageStatus  @default(PENDING)
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
  schoolId      String
  senderId      String
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender        User           @relation("MessageSender", fields: [senderId], references: [id])
}

model AiSettings {
  id              String   @id @default(cuid())
  schoolId        String   @unique
  teacherPrompt   String   @default("Generate a professional and encouraging class teacher's comment for a student based on these details:\nName: {{name}}\nGender: {{gender}}\nTerm: {{term}}\nAverage Score: {{average}}%\nClass Position: {{position}}\nAttendance: {{attendance}}\nTraits: {{traits}}\n\nThe comment should be around 2-3 sentences.")
  principalPrompt        String   @default("Generate a concise principal's closing remark for a student based on their overall performance:\nAverage Score: {{average}}%\nClass Position: {{position}}\nAttendance: {{attendance}}.\n\nKeep it professional and focused on growth.")
  useMultiAgentComments Boolean  @default(false)
  commentConfig   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

enum SchoolRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SchoolCategory {
  PRIMARY
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  PROPRIETOR
  CLASS_TEACHER
  SUBJECT_TEACHER
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
}

enum ClassLevel {
  NURSERY
  PRIMARY
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
}

enum SubjectCategory {
  CORE
  SCIENCE
  ARTS
  COMMERCIAL
  VOCATIONAL
  LANGUAGE
}

enum SubjectKind {
  STANDARD
  COMPOSITE_PARENT
  COMPOSITE_COMPONENT
}

enum AttendancePeriod {
  MORNING
  AFTERNOON
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  ONLINE
}

enum MessageChannel {
  SMS
  EMAIL
  IN_APP
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum ScoreUploadStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScoreWorkflowStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  BROADCASTED
}

enum ScoreWorkflowActionType {
  SAVED
  APPROVED
  REJECTED
  BROADCASTED
  REOPENED
}

enum ReportType {
  HALF_TERM
  END_TERM
}

enum ClassReportWorkflowStatus {
  WAITING_SUBJECT_BROADCAST
  RESULT_BROADCASTED
  COMMENTS_GENERATED
  READY_FOR_ADMIN_REVIEW
  PUBLISHED
  UNPUBLISHED
}

enum StudentReportWorkflowStatus {
  COMMENTS_PENDING
  COMMENTS_READY
  CLASS_APPROVED
  ADMIN_APPROVED
  ADMIN_REJECTED
  PUBLISHED
  UNPUBLISHED
}

enum NotificationType {
