// ─── Scheme of Work ────────────────────────────────────────────────────────────

enum SowStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model SchemeOfWork {
  id           String    @id @default(cuid())
  schoolId     String
  subjectId    String
  classId      String
  sessionId    String
  title        String
  status       SowStatus @default(DRAFT)
  adminNote    String?
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?
  ownerId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school        School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject       Subject                    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class         Class                      @relation(fields: [classId], references: [id], onDelete: Cascade)
  session       AcademicSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  owner         User                       @relation("SOWOwner", fields: [ownerId], references: [id])
  approvedBy    User?                      @relation("SOWApprover", fields: [approvedById], references: [id])
  terms         SchemeOfWorkTerm[]
  collaborators SchemeOfWorkCollaborator[]
  classArms     SchemeOfWorkClassArm[]

  @@unique([subjectId, classId, sessionId])
  @@index([schoolId, status])
}

model SchemeOfWorkClassArm {
  id             String   @id @default(cuid())
  schemeOfWorkId String
  classArmId     String
  createdAt      DateTime @default(now())

  schemeOfWork SchemeOfWork @relation(fields: [schemeOfWorkId], references: [id], onDelete: Cascade)
  classArm     ClassArm     @relation(fields: [classArmId], references: [id], onDelete: Cascade)

  @@unique([schemeOfWorkId, classArmId])
  @@index([schemeOfWorkId])
}

model SchemeOfWorkTerm {
  id               String    @id @default(cuid())
  schemeOfWorkId   String
  termId           String
  termNumber       Int
  objectives       String?
  // Per-term approval workflow
  status           SowStatus @default(DRAFT)
  adminNote        String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  approvedById     String?
  // Frozen snapshot of week data taken at approval time (used by lesson builder)
  approvedSnapshot Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  schemeOfWork SchemeOfWork       @relation(fields: [schemeOfWorkId], references: [id], onDelete: Cascade)
  term         Term               @relation(fields: [termId], references: [id])
  approvedBy   User?              @relation("SOWTermApprover", fields: [approvedById], references: [id])
  weeks        SchemeOfWorkWeek[]

  @@unique([schemeOfWorkId, termNumber])
  @@index([schemeOfWorkId])
  @@index([schemeOfWorkId, status])
}

model SchemeOfWorkWeek {
  id                 String   @id @default(cuid())
  schemeOfWorkTermId String
  weekNumber         Int
  topic              String
  content            String?
  objectives         String?
  resources          String?
  teachingMethods    String?
  assessment         String?
  waecObjectives     String?
  jambObjectives     String?
  igcseObjectives    String?
  objectiveSegments  Json?
  objectivesApproved Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  schemeOfWorkTerm SchemeOfWorkTerm            @relation(fields: [schemeOfWorkTermId], references: [id], onDelete: Cascade)
  references       SchemeOfWorkWeekReference[]
  sdgMappings      SchemeOfWorkWeekSdg[]

  @@unique([schemeOfWorkTermId, weekNumber])
  @@index([schemeOfWorkTermId])
}

model SchemeOfWorkWeekReference {
  id          String   @id @default(cuid())
  weekId      String
  type        String
  title       String
  url         String?
  fileKey     String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  week SchemeOfWorkWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
}

model SchemeOfWorkWeekSdg {
  id          String   @id @default(cuid())
  weekId      String
  sdgNumber   Int
  aiSuggested Boolean  @default(false)
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  week SchemeOfWorkWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, sdgNumber])
  @@index([weekId])
}

model SchemeOfWorkCollaborator {
  id             String   @id @default(cuid())
  schemeOfWorkId String
  userId         String
  invitedById    String
  createdAt      DateTime @default(now())

  schemeOfWork SchemeOfWork @relation(fields: [schemeOfWorkId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schemeOfWorkId, userId])
  @@index([schemeOfWorkId])
}

// ─── Multi-Branch Support ──────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  School[]
}

model UserBranch {
  id           String     @id @default(cuid())
  userId       String
  schoolId     String
  roles        UserRole[]
  isActive     Boolean    @default(true)
  assignedAt   DateTime   @default(now())
  assignedById String?
  user         User       @relation("UserBranches", fields: [userId], references: [id], onDelete: Cascade)
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignedBy   User?      @relation("BranchAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

model StudentTransfer {
  id              String    @id @default(cuid())
  studentId       String
  fromBranchId    String
  toBranchId      String
  fromClassArmId  String?
  toClassArmId    String?
  transferDate    DateTime  @default(now())
  reason          String?
  transferredById String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromBranch      School    @relation("TransferFrom", fields: [fromBranchId], references: [id], onDelete: Restrict)
  toBranch        School    @relation("TransferTo", fields: [toBranchId], references: [id], onDelete: Restrict)
  fromClassArm    ClassArm? @relation("TransferFromArm", fields: [fromClassArmId], references: [id], onDelete: SetNull)
  toClassArm      ClassArm? @relation("TransferToArm", fields: [toClassArmId], references: [id], onDelete: SetNull)
  transferredBy   User      @relation("TransferActor", fields: [transferredById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([fromBranchId])
  @@index([toBranchId])
}
