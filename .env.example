# Environment Configuration
# Copy this file to .env.local for local development.
# For Vercel production, set these in Project Settings -> Environment Variables.

# -----------------------------------------------------------------------------
# Required for app auth + database
# -----------------------------------------------------------------------------

# Runtime database URL (recommended: Neon pooled URL).
# Example:
# DATABASE_URL="postgresql://<user>:<password>@<neon-pooled-host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"

# Public app URL (set to your Vercel domain or custom domain in production).
# Example: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Tenant subdomains (optional): school portals at https://{slug}.{ROOT}/...
# When enabled, portal links use subdomain URLs; middleware redirects tenant / and /auth/login to /s/{slug}/login.
NEXT_PUBLIC_USE_TENANT_SUBDOMAINS="false"
# Bare root domain only (e.g. edunostics.com) — no https://, no path, no leading "www."
# Must match wildcard DNS: *.edunostics.com → same Vercel project.
NEXT_PUBLIC_APP_ROOT_DOMAIN=""

# --- Vercel + edunostics.com (production testing) --------------------------------
# 1) Vercel → Project → Settings → Domains: add edunostics.com, www.edunostics.com, *.edunostics.com
#    (wildcard enables https://{school-slug}.edunostics.com for each School.slug).
# 2) DNS at your registrar: point apex + www + * per Vercel’s records (often CNAME / ALIAS).
# 3) Environment variables (Production):
#      DATABASE_URL=<your pooled Postgres URL>
#      NEXTAUTH_SECRET=<openssl rand -base64 32>
#      NEXTAUTH_URL="https://edunostics.com"
#      NEXT_PUBLIC_USE_TENANT_SUBDOMAINS="true"
#      NEXT_PUBLIC_APP_ROOT_DOMAIN="edunostics.com"
# 4) Each school needs a unique DNS-safe slug in School.slug (matches subdomain label).
# 5) Smoke tests: https://edunostics.com (landing), https://{slug}.edunostics.com/ → school login,
#    https://edunostics.com/s/{slug}/login → redirects to tenant subdomain when (2–3) are true.
# NextAuth uses trustHost so sign-in works on both apex and tenant hosts (sessions are per-host).

# -----------------------------------------------------------------------------
# Optional: HTTP smoke tests against production (run manually — not required for CI)
# -----------------------------------------------------------------------------
# npm run test:smoke
#   SMOKE_APEX_URL=https://edunostics.com SMOKE_SCHOOL_SLUG=tis npm run test:smoke
# Requires a real School.slug matching SMOKE_SCHOOL_SLUG and DNS for *.edunostics.com.
# SMOKE_SKIP_TENANT_HOST=1 — run only apex checks (wildcard DNS not ready).
# SMOKE_STRICT=1 — fail if tenant / does not redirect (subdomain mode must be fully on).

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Optional for local migration workflows
# -----------------------------------------------------------------------------

# Direct Neon (non-pooled) URL for schema migrations run from local/CI.
# Keep empty if not used.
DIRECT_DATABASE_URL=""

# -----------------------------------------------------------------------------
# Optional feature integrations
# -----------------------------------------------------------------------------

# AI comments (Gemini)
GEMINI_API_KEY=""

# AI-powered SOW generation (OpenRouter)
# Models used: openrouter/hunter-alpha (primary), nvidia/nemotron-3-super-120b-a12b:free (fallback)
OPENROUTER_API_KEY=""

# SMS Integration (Termii)
TERMII_API_KEY=""
TERMII_SENDER_ID="EduCare"

# Payment Integration (Paystack)
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# AES-256-GCM key for encrypting communication credentials (smsApiKey, emailPassword)
# stored in the database. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable encryption (not recommended for production).
COMMS_ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Google Drive Picker (optional — used in Lesson Editor)
# -----------------------------------------------------------------------------
# IMPORTANT: Restrict the API key in Google Cloud Console to your domain(s)
# under API & Services -> Credentials -> HTTP referrers. Without referrer
# restrictions, the key can be abused by third parties.
NEXT_PUBLIC_GOOGLE_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
