# Environment Configuration
# Copy this file to .env.local for local development.
# For Vercel production, set these in Project Settings -> Environment Variables.

# -----------------------------------------------------------------------------
# Required for app auth + database
# -----------------------------------------------------------------------------

# Runtime database URL (recommended: Neon pooled URL).
# Example:
# DATABASE_URL="postgresql://<user>:<password>@<neon-pooled-host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"

# Public app URL (set to your Vercel domain or custom domain in production).
# Example: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Optional for local migration workflows
# -----------------------------------------------------------------------------

# Direct Neon (non-pooled) URL for schema migrations run from local/CI.
# Keep empty if not used.
DIRECT_DATABASE_URL=""

# -----------------------------------------------------------------------------
# Optional feature integrations
# -----------------------------------------------------------------------------

# AI comments (Gemini)
GEMINI_API_KEY=""

# AI-powered SOW generation (OpenRouter)
# Models used: openrouter/hunter-alpha (primary), nvidia/nemotron-3-super-120b-a12b:free (fallback)
OPENROUTER_API_KEY=""

# SMS Integration (Termii)
TERMII_API_KEY=""
TERMII_SENDER_ID="EduCare"

# Payment Integration (Paystack)
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# AES-256-GCM key for encrypting communication credentials (smsApiKey, emailPassword)
# stored in the database. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable encryption (not recommended for production).
COMMS_ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Google Drive Picker (optional — used in Lesson Editor)
# -----------------------------------------------------------------------------
# IMPORTANT: Restrict the API key in Google Cloud Console to your domain(s)
# under API & Services -> Credentials -> HTTP referrers. Without referrer
# restrictions, the key can be abused by third parties.
NEXT_PUBLIC_GOOGLE_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
